<Window x:Class="AppUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обувной магазин" 
        Height="450" 
        Width="800">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2E8B57" Padding="10">
            <TextBlock Text="Обувной магазин" FontSize="24" Foreground="White" 
                       FontWeight="Bold" HorizontalAlignment="Center"/>
        </Border>
        
        <StackPanel Grid.Row="1" Margin="10" Orientation="Horizontal" HorizontalAlignment="Center">
            <TextBox x:Name="LoginBox" Width="150" Margin="5" Text="admin"/>
            <PasswordBox x:Name="PasswordBox" Width="150" Margin="5"/>
            <Button x:Name="LoginButton" Content="Войти" Width="80" Margin="5" Click="LoginButton_Click"/>
            <Button x:Name="GuestButton" Content="Гость" Width="80" Margin="5" Click="GuestButton_Click"/>
            <TextBlock x:Name="UserInfo" Margin="20,0,0,0" FontWeight="Bold"/>
        </StackPanel>
        
        <ListBox x:Name="ProductsList" Grid.Row="2" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="5" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding Name}" Width="200" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Brand}" Width="100"/>
                            <TextBlock Text="{Binding Count}" Width="80"/>
                            <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                            <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:C}}" Width="100" Foreground="Green"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>