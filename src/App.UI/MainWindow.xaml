<Window x:Class="AppUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:AppUI.Converters"
        Title="Обувной магазин" 
        Height="700" 
        Width="1100"
        MinWidth="800"
        MinHeight="500"
        Background="#1E1E1E">
    
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
    </Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Шапка -->
        <Border Grid.Row="0" Background="#2E8B57" Padding="15">
            <TextBlock Text="👞 Обувной магазин" FontSize="28" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <!-- Панель входа -->
        <WrapPanel Grid.Row="1" HorizontalAlignment="Center" Margin="10">
            <TextBox x:Name="LoginBox" Text="admin" Width="150" Margin="5" Background="#2D2D2D" Foreground="White"/>
            <PasswordBox x:Name="PasswordBox" Width="150" Margin="5" Background="#2D2D2D" Foreground="White"/>
            <Button x:Name="LoginButton" Content="Войти" Width="80" Margin="5" Background="#2E8B57" Foreground="White"/>
            <Button x:Name="GuestButton" Content="Гость" Width="80" Margin="5" Background="#3D3D3D" Foreground="White"/>
            <TextBlock x:Name="UserInfo" VerticalAlignment="Center" Margin="20,0,0,0" Foreground="White"/>
            <Button x:Name="CartButton" Content="🛒 Корзина" Width="100" Margin="20,5,5,5" Background="#2E8B57" Foreground="White" Visibility="Collapsed"/>
        </WrapPanel>
        
        <!-- Панель управления (админ) -->
        <WrapPanel x:Name="AdminPanel" Grid.Row="2" HorizontalAlignment="Center" Visibility="Collapsed" Margin="10">
            <TextBlock Text="⚙️ Управление:" Foreground="White" VerticalAlignment="Center" Margin="5,0,10,0" FontWeight="Bold"/>
            <Button x:Name="AddProductButton" Content="➕ Добавить товар" Width="130" Margin="5" Background="#2E8B57" Foreground="White"/>
            <Button x:Name="RefreshButton" Content="🔄 Обновить" Width="100" Margin="5" Background="#3D3D3D" Foreground="White"/>
        </WrapPanel>
        
        <!-- Панель поиска и фильтрации -->
        <WrapPanel x:Name="SearchPanel" Grid.Row="3" HorizontalAlignment="Center" Margin="10" Visibility="Visible">
            <TextBlock Text="🔍 Поиск:" Foreground="White" VerticalAlignment="Center" Margin="5"/>
            <TextBox x:Name="SearchBox" Width="200" Margin="5" Background="#2D2D2D" Foreground="White"/>
            
            <TextBlock Text="🏭 Поставщик:" Foreground="White" VerticalAlignment="Center" Margin="15,5,5,5"/>
            <ComboBox x:Name="ProviderFilter" Width="150" Margin="5" Background="#2D2D2D" Foreground="White">
                <ComboBoxItem Content="Все поставщики" IsSelected="True" Background="#2D2D2D" Foreground="White"/>
            </ComboBox>
            
            <TextBlock Text="📊 Сортировка:" Foreground="White" VerticalAlignment="Center" Margin="15,5,5,5"/>
            <ComboBox x:Name="SortByCombo" Width="180" Margin="5" Background="#2D2D2D" Foreground="White">
                <ComboBoxItem Content="Без сортировки" IsSelected="True" Background="#2D2D2D" Foreground="White"/>
                <ComboBoxItem Content="По количеству (возрастание)" Background="#2D2D2D" Foreground="White"/>
                <ComboBoxItem Content="По количеству (убывание)" Background="#2D2D2D" Foreground="White"/>
                <ComboBoxItem Content="По цене (возрастание)" Background="#2D2D2D" Foreground="White"/>
                <ComboBoxItem Content="По цене (убывание)" Background="#2D2D2D" Foreground="White"/>
            </ComboBox>
            
            <TextBlock Text="Найдено:" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <TextBlock x:Name="CountText" Text="0" Foreground="#2E8B57" VerticalAlignment="Center" FontWeight="Bold"/>
        </WrapPanel>
        
        <!-- Список товаров -->
        <ScrollViewer Grid.Row="4" Margin="10" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="ProductsList" Background="Transparent">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="1" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252526" CornerRadius="8" Margin="5" Padding="10" BorderBrush="#3D3D3D" BorderThickness="1" MinHeight="75">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <!-- Фото -->
                                <Border Grid.Column="0" Width="50" Height="50" CornerRadius="8" Background="#2D2D2D">
                                    <Image Width="50" Height="50" Stretch="UniformToFill" Source="{Binding Photo, FallbackValue=/Images/placeholder.png}"/>
                                </Border>
                                
                                <!-- Название -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="Bold" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Brand}" FontSize="12" Foreground="#CCCCCC" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                
                                <!-- Категория -->
                                <TextBlock Grid.Column="2" Text="{Binding CategoryName}" VerticalAlignment="Center" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Поставщик -->
                                <TextBlock Grid.Column="3" Text="{Binding Provider}" VerticalAlignment="Center" Foreground="White" TextTrimming="CharacterEllipsis"/>
                                
                                <!-- Количество -->
                                <StackPanel Grid.Column="4" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="В наличии" FontSize="9" Foreground="#CCCCCC" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Count}" FontSize="20" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center"/>
                                </StackPanel>
                                
                                <!-- Цена -->
                                <StackPanel Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Price, StringFormat={}{0:C}}" FontSize="11" Foreground="#DC3545" TextDecorations="Strikethrough" 
                                               Visibility="{Binding HasHighDiscount, Converter={StaticResource BoolToVisibility}}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding FinalPrice, StringFormat={}{0:C}}" FontSize="17" FontWeight="Bold" Foreground="#2E8B57" HorizontalAlignment="Right"/>
                                </StackPanel>
                                
                                <!-- Кнопки -->
                                <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                                    <Button x:Name="AddToCartButton" Content="🛒" Width="32" Height="32" Margin="2" Tag="{Binding}" Click="AddToCart_Click" Background="#3D3D3D" Foreground="White" FontSize="16"/>
                                    <Button x:Name="EditButton" Content="✏️" Width="32" Height="32" Margin="2" Tag="{Binding Id}" Click="EditProduct_Click" Background="#3D3D3D" Foreground="White" FontSize="14"
                                            Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                    <Button x:Name="DeleteButton" Content="🗑️" Width="32" Height="32" Margin="2" Tag="{Binding Id}" Click="DeleteProduct_Click" Background="#DC3545" Foreground="White" FontSize="14"
                                            Visibility="{Binding DataContext.IsAdmin, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}, Converter={StaticResource BoolToVisibility}}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        
        <!-- Нижняя панель -->
        <Border Grid.Row="5" Background="#2D2D2D" Padding="10">
            <TextBlock Text="© 2026 Обувной магазин" Foreground="#CCCCCC" FontSize="11" HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>