<Window x:Class="AppUI.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Редактирование товара" 
        Height="600" 
        Width="520"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Добавление/Редактирование товара" 
                   FontSize="18" FontWeight="Bold" Foreground="#E0E0E0" Margin="0,0,0,20"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Text="ID:" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="IdBox" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Наименование:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="NameBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Категория:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <ComboBox x:Name="CategoryBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Описание:" Foreground="#E0E0E0" VerticalAlignment="Top"/>
        <TextBox x:Name="DescriptionBox" Grid.Row="4" Grid.Column="1" Height="60" TextWrapping="Wrap" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Производитель:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="BrandBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Поставщик:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="ProviderBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Цена:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="PriceBox" Grid.Row="7" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Ед. измерения:" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <ComboBox x:Name="UnitBox" Grid.Row="8" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0">
            <ComboBoxItem Content="пара" IsSelected="True" Background="#2D2D2D" Foreground="#E0E0E0"/>
            <ComboBoxItem Content="шт" Background="#2D2D2D" Foreground="#E0E0E0"/>
        </ComboBox>
        
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Количество:*" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="CountBox" Grid.Row="9" Grid.Column="1" Margin="0,0,0,10" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <TextBlock Grid.Row="10" Grid.Column="0" Text="Скидка (%):" Foreground="#E0E0E0" VerticalAlignment="Center"/>
        <TextBox x:Name="DiscountBox" Grid.Row="10" Grid.Column="1" Text="0" Margin="0,0,0,20" Background="#2D2D2D" Foreground="#E0E0E0"/>
        
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="SaveButton" Content="💾 Сохранить" Width="100" Margin="10" Background="#2E8B57" Foreground="White"/>
            <Button x:Name="CancelButton" Content="❌ Отмена" Width="100" Margin="10" Background="#3D3D3D" Foreground="#E0E0E0"/>
        </StackPanel>
    </Grid>
</Window>
