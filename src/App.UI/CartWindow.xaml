<Window x:Class="AppUI.CartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Корзина" 
        Height="500" 
        Width="800"
        Background="#1E1E1E"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#2E8B57" Padding="15" CornerRadius="12" Margin="0,0,0,15">
            <TextBlock Text="🛒 Моя корзина" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
        </Border>
        
        <ScrollViewer Grid.Row="1">
            <ListBox x:Name="CartListBox" Background="Transparent" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#252526" CornerRadius="12" Margin="0,10,0,0" Padding="15" BorderBrush="#3D3D3D" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding Product.Name}" FontSize="16" FontWeight="Bold" Foreground="White"/>
                                    <TextBlock Text="{Binding Product.Brand}" FontSize="12" Foreground="#CCCCCC"/>
                                    <TextBlock Text="{Binding Product.Price, StringFormat={}{0:C}}" FontSize="12" Foreground="#DC3545" TextDecorations="Strikethrough"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Button x:Name="DecreaseBtn" Content="-" Width="30" Height="30" Margin="2" Click="DecreaseQuantity_Click" Tag="{Binding}" Background="#3D3D3D" Foreground="White"/>
                                    <TextBlock Text="{Binding Quantity}" FontSize="18" FontWeight="Bold" Foreground="White" MinWidth="40" TextAlignment="Center"/>
                                    <Button x:Name="IncreaseBtn" Content="+" Width="30" Height="30" Margin="2" Click="IncreaseQuantity_Click" Tag="{Binding}" Background="#3D3D3D" Foreground="White"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding TotalPrice, StringFormat={}{0:C}}" FontSize="18" FontWeight="Bold" Foreground="#2E8B57"/>
                                </StackPanel>
                                
                                <Button Grid.Column="3" Content="🗑️" Width="40" Margin="10,0,0,0" Click="RemoveFromCart_Click" Tag="{Binding}" Background="#DC3545" Foreground="White"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </ScrollViewer>
        
        <Border Grid.Row="2" Background="#252526" CornerRadius="12" Padding="15" Margin="0,15,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Итого:" FontSize="20" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="TotalPriceText" Grid.Column="1" FontSize="24" FontWeight="Bold" Foreground="#2E8B57"/>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="ClearCartButton" Content="Очистить корзину" Width="150" Margin="10" Background="#DC3545" Foreground="White"/>
            <Button x:Name="ContinueShoppingButton" Content="Продолжить покупки" Width="150" Margin="10" Background="#3D3D3D" Foreground="White"/>
            <Button x:Name="CheckoutButton" Content="✅ Оформить заказ" Width="150" Margin="10" Background="#2E8B57" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
